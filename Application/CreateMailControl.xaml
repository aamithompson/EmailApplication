<UserControl x:Class="EmailApplication.CreateMailControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EmailApplication"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <!-- Outer Container -->
    <Grid>
        <DockPanel>
            <!-- Navigation Bar -->
            <Border DockPanel.Dock="Top" Background="White" BorderBrush="#CCCCCC" BorderThickness="1" Padding="0, 4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Side -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="Email Application " FontWeight="Bold" FontSize="16"/>
                        <Border Width="2" Height="24" Background="#CCCCCC" Margin="8,0"/>
                        <Button Content="←" Width="32" Click="BackButton_Click"/>
                    </StackPanel>

                    <!-- Right Side -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Content="X" Width="16" Margin="8, 0"/>
                        <Button Content="C" Width="16" Margin="8, 0"/>
                        <Button Content=">" Click="SendButton_Click" Width="16" Margin="8, 0"/>
                        <Button Content=". . ." Width="24" Margin="8, 0"/>
                        <Border Width="2" Height="24" Background="#CCCCCC" Margin="8,0"/>
                        <Button Margin="4, 0" Padding="4, 0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="24" Height="24" CornerRadius="12" Background="#5B9BD5" Margin="0,0,6,0">
                                    <TextBlock Text="A" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                </Border>
                                <TextBlock Text="Account" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
            <!-- Email Display Box -->
            <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Subject Bar -->
                    <Border Grid.Row="0" Background="White" BorderBrush="#CCCCCC" BorderThickness="1" Padding="0, 8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Subject: " FontWeight="Bold" Margin="0, 0, 8, 0"/>
                            
                            <TextBox x:Name="SubjectTextBox" Grid.Column="1" Text="{Binding Subject, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent"/>
                            <TextBlock Grid.Column="1" Text="Enter Subject . . ." Foreground="#AAAAAA" IsHitTestVisible="False" Margin="2, 0, 0, 0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Subject}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding Subject}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Sender Bar -->
                    <Border Grid.Row="1" Background="White" BorderBrush="#CCCCCC" BorderThickness="1" Padding="0, 8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Sender: " FontWeight="Bold" Width="80"/>
                            <TextBlock Text="{Binding Sender}"/>
                        </StackPanel>
                    </Border>

                    <!-- Recipients -->
                    <Border Grid.Row="2" Background="White" BorderBrush="#CCCCCC" BorderThickness="1" Padding="0, 8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Recipient(s): " FontWeight="Bold" Width="80"/>
                            <TextBox x:Name="RecipientsTextBox" Grid.Column="1" Text="{Binding Recipients, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent"/>
                            <TextBlock Grid.Column="1" Text="Enter Recipients. . ." Foreground="#AAAAAA" IsHitTestVisible="False" Margin="2, 0, 0, 0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Recipients}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding Recipients}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Body -->
                    <Border Grid.Row="3" BorderBrush="#CCCCCC" BorderThickness="1">
                        <Grid>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                                <TextBox Text="{Binding Body, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="False" BorderThickness="0" TextWrapping="Wrap"/>
                            </ScrollViewer>

                            <TextBlock Text="Enter Email Body. . ." Foreground="#AAAAAA" IsHitTestVisible="False" Padding="10">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Body}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding Body}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Files Attached -->
                    <Border Grid.Row="4" BorderBrush="#CCCCCC" BorderThickness="1">
                        <TextBlock Text="File(s) Attached:"/>
                    </Border>
                </Grid>
            </Border>
        </DockPanel>
    </Grid>
</UserControl>
