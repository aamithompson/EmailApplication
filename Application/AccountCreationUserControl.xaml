<UserControl x:Class="EmailApplication.AccountCreationUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EmailApplication"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1" Padding="16">
        <StackPanel Orientation="Vertical" Margin="64, 0" VerticalAlignment="Center">
            <!-- Greeting -->
            <TextBlock Text="Create Account" TextAlignment="Center" FontSize="24" FontWeight="Bold" Margin="0, 0, 0, 16"/>

            <!-- Account Name -->
            <StackPanel Orientation="Vertical" Margin="128, 0, 128, 8">
                <TextBlock Text="Account Name" TextAlignment="Center" FontSize="16"/>
                <TextBox x:Name="AccountNameTextBox" Text="{Binding AccountName, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center"/>
            </StackPanel>

            <!-- Email Address -->
            <StackPanel Orientation="Vertical" Margin="128, 0, 128, 8">
                <TextBlock Text="Email Address" TextAlignment="Center" FontSize="16"/>
                <TextBox x:Name="EmailAddressTextBox" Text="{Binding EmailAddress, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center"/>
            </StackPanel>

            <!-- Password -->
            <StackPanel Orientation="Vertical" Margin="128, 0, 128, 8">
                <TextBlock Text="Password" TextAlignment="Center" FontSize="16"/>
                <PasswordBox x:Name="PasswordTextBox" HorizontalContentAlignment="Center"/>
            </StackPanel>

            <!-- Create Account -->
            <Button Click="CreateAccountButton_Click" Content="Create Account" Margin="128, 8, 128, 0"/>

            <!-- Sign In -->
            <StackPanel Orientation="Vertical" Margin="128, 64, 128, 0">
                <TextBlock Text="Already Have an Account?" TextAlignment="Center"/>
                <Button Click="SignInButton_Click" Content="Sign In"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
