<UserControl x:Class="EmailApplication.InboxControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EmailApplication"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <!-- Outer Container -->
    <Grid>
        <DockPanel>
            <!-- Navigation Bar -->
            <Border DockPanel.Dock="Top" Background="White" BorderBrush="#CCCCCC" BorderThickness="1" Padding="0, 4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Side -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="Email Application " FontWeight="Bold" FontSize="16"/>
                        <Border Width="2" Height="24" Background="#CCCCCC" Margin="8,0"/>
                    </StackPanel>
                    
                    <!-- Middle -->

                    <DockPanel Grid.Column="1">
                        <Button DockPanel.Dock="Left" Content="R" Width="24" Margin="0, 0, 8, 0" Click="RefreshButton_Click"/>
                        <Border BorderBrush="#CCCCCC" BorderThickness="1">
                            <DockPanel>
                                <Button DockPanel.Dock="Left" Content="=" Width="32" Margin="4, 0"/>
                                <TextBox Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" BorderThickness="0"/>
                            </DockPanel>
                        </Border>
                    </DockPanel>

                    <!-- Right Side -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Border Width="2" Height="24" Background="#CCCCCC" Margin="8,0"/>
                        <Button Margin="4, 0" Padding="4, 0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="24" Height="24" CornerRadius="12" Background="#5B9BD5" Margin="0,0,6,0">
                                    <TextBlock Text="A" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                </Border>
                                <TextBlock Text="Account" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
            <!-- Inbox -->
            <DockPanel>
                <!-- Inbox Folders -->
                <Border DockPanel.Dock="Left" Width="150" Background="White" BorderBrush="#CCCCCC">
                    <Grid>
                        <!-- Definitions -->
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Vertical">
                            <Button Content="Inbox"/>
                            <Button Content="Marked"/>
                            <Button Content="Sent"/>
                            <Button Content="Drafts"/>
                            <Button Content="Trash"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Vertical">
                            <Button Content="Create Mail" Click="CreateMailButton_Click"/>
                            <Button Content="Settings"/>
                            <Button Content="Help"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Inbox List -->
                <Border Background="White" BorderBrush="#CCCCCC">
                    <ListView ItemsSource="{Binding Emails}" BorderThickness="0" x:Name="InboxList" SelectionChanged="InboxList_SelectionChanged" ScrollViewer.ScrollChanged="InboxList_ScrollChanged">
                        <!-- Config -->
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="BorderBrush" Value="#CCCCCC"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </ListView.ItemContainerStyle>

                        <!-- Email -->
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <!-- Definitions -->
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Sender -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Sender}"/>
                                    
                                    <!-- Subject -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Subject}"/>
                                    
                                    <!-- Preview -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Preview}"/>
                                    
                                    <!-- Date -->
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DateReceived}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>
            </DockPanel>
        </DockPanel>
    </Grid>
</UserControl>
